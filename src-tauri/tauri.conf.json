{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "konvert",
  "version": "0.1.0",
  "identifier": "com.konvert.dev",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:4567",
    "beforeDevCommand": "ruby app.rb"
  },
  "app": {
    "windows": [
      {
        "title": "konvert",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
